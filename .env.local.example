# Brevo (Email Service)
BREVO_API_KEY=your_brevo_api_key_here

# Umami Analytics
# Get these from https://cloud.umami.is/ (recommended) or your self-hosted instance
# Website ID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (UUID)
# Script URL examples:
#   Umami Cloud: https://cloud.umami.is/script.js
#   Self-hosted: https://your-analytics.vercel.app/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# Sanity CMS (Blog Content Management)
# Get these from https://sanity.io/manage after creating a project
# Project ID format: xxxxxxxx (8 characters, e.g., abc123de)
# Dataset: usually "production"
# API Token: Only needed for write operations (optional for reading public content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token_optional

# ==============================================================================
# Supabase (Database & Auth) - REQUIRED FOR TIER 1
# ==============================================================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
# 
# Project URL format: https://xxxxxxxxxxxxx.supabase.co
# Anon Key: Public key for client-side use (eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
# Service Role Key: Secret key for server-side use (eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
#
# IMPORTANT: Keep the Service Role Key secret - never expose to client!

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ==============================================================================
# Authentication (Magic Links)
# ==============================================================================
# JWT Secret: Generate a secure random string (min 32 characters)
# Recommended: openssl rand -base64 32
# Used for signing magic link tokens (48-hour expiry)

JWT_SECRET=your_jwt_secret_here_min_32_characters

# Public URL: Your site URL (localhost for dev, production URL for prod)
NEXT_PUBLIC_URL=http://localhost:3000

# ==============================================================================
# LLM (Anthropic Claude)
# ==============================================================================
# Get API key from: https://console.anthropic.com/account/keys
# Format: sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model: claude-3-5-haiku-20241022 (cost-optimized, ~$0.10/report)

ANTHROPIC_API_KEY=your_anthropic_api_key

# ==============================================================================
# External APIs
# ==============================================================================
# HIBP (Have I Been Pwned) API Key
# Get from: https://haveibeenpwned.com/API/Key
# Cost: $3.50/month for unlimited API access
# Used to check domain breaches

HIBP_API_KEY=your_hibp_api_key

# ==============================================================================
# Email (Brevo) - REQUIRED FOR TIER 1
# ==============================================================================
# Already configured above, but adding template IDs and settings

# Brevo Template IDs (create these in Brevo dashboard)
BREVO_TEMPLATE_SNAPSHOT_COMPLETE=1
BREVO_TEMPLATE_ACCOUNT_WELCOME=2
BREVO_TEMPLATE_REPORT_EXPIRING=3

# Email Configuration
SYSTEM_EMAIL_FROM=reports@explainmyit.com
SYSTEM_EMAIL_FROM_NAME=Explain My IT
SYSTEM_EMAIL_REPLY_TO=hello@explainmyit.com

# Webhook Security (generate random string)
BREVO_WEBHOOK_SECRET=your_brevo_webhook_secret
