# Brevo (Email Service)
BREVO_API_KEY=your_brevo_api_key_here

# Umami Analytics
# Get these from https://cloud.umami.is/ (recommended) or your self-hosted instance
# Website ID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (UUID)
# Script URL examples:
#   Umami Cloud: https://cloud.umami.is/script.js
#   Self-hosted: https://your-analytics.vercel.app/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# Sanity CMS (Blog Content Management)
# Get these from https://sanity.io/manage after creating a project
# Project ID format: xxxxxxxx (8 characters, e.g., abc123de)
# Dataset: usually "production"
# API Token: Only needed for write operations (optional for reading public content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token_optional

# Supabase (Future - Not used in v1)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
